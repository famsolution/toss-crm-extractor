{
  "manifest_version": 3,
  "name": "토스인슈 CRM 데이터 추출기",
  "version": "3.10.0",
  "description": "토스인슈 CRM 데이터 추출 — 마스킹 자동 복원 + 로그인/관리자 승인 권한 게이트.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "clipboardWrite",
    "scripting"
  ],
  "host_permissions": [
    "https://crm.tossinsu.com/*",
    "https://mmlfcp.ohmymanager.com/*",
    "https://*.ohmymanager.com/*",
    "file:///*",
    "http://localhost/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "토스인슈 CRM 추출기"
  },
  "content_scripts": [
    {
      "matches": [
        "https://crm.tossinsu.com/*",
        "https://mmlfcp.ohmymanager.com/*",
        "https://*.ohmymanager.com/*",
        "https://tossinssu-pro.vercel.app/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
